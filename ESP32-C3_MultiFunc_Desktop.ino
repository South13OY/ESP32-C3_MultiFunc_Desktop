void drawGIF() {
    int idx = ((millis() - gifStartTime) / 70) % numbitmaps;
    uint8_t reversed[1024];
    const uint8_t* src = bitmaps[idx];
    for (int i = 0; i < 1024; i++) reversed[i] = reverse_byte(src[i]);
    u8g2.firstPage();
    do {
        u8g2.drawXBMP(0, 6, 128, 64, reversed);
    } while (u8g2.nextPage());
}

void drawHealth() {
    u8g2.firstPage();
