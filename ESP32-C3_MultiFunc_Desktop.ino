/*
 * ESP32-C3 多功能桌面摆件：时钟 + 天气 + GIF动画 + 恐龙小游戏 + 健康监测
 * 按钮：GPIO2左, GPIO3右, GPIO4返回, GPIO5确认/跳跃
 */

// ==================== 头文件 ====================
#include <Wire.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <time.h>
#include <U8g2lib.h>
#include <MAX30105.h>
#include <heartRate.h>
#include <spo2_algorithm.h>
#include <Preferences.h>
#include <WebServer.h>
#include <DNSServer.h>

// ==================== 宏定义 ====================
// 按钮引脚
#define BTN_LEFT    2
#define BTN_RIGHT   3
#define BTN_BACK    4
#define BTN_OK      5

// I2C 和 OLED
#define OLED_ADDR   0x3C
#define I2C_SDA     1
#define I2C_SCL     0

// MAX30102 I2C 地址
#define MAX30102_ADDR  0x57

// 天气和 WiFi
#define WEATHER_API_KEY        "这里替换心知API"
#define WEATHER_UPDATE_INTERVAL  1800000   // 30分钟

// NTP 时区
const long gmtOffset_sec = 8 * 3600;
const int  daylightOffset_sec = 0;

// 健康监测参数
#define FINGER_DETECT_THRESHOLD  5000
#define HEALTH_READ_MS  10

// 时钟动画
#define ANIM_DURATION 150
#define FONT_HEIGHT   24
#define Y_BASE        50
#define MOVE_UP       20
#define TOP_LIMIT     24
const int digitX[6] = { 0, 18, 44, 62, 88, 106 };
const int colonX[2] = { 36, 80 };

// 菜单
#define MENU_ANIM_DURATION 500

// 游戏
#define GRAVITY       0.6
#define JUMP_VEL      -4.5
#define GROUND_Y      54
#define DINO_X        10
#define DINO_W        8
#define DINO_H        10
#define OBSTACLE_W    5
#define OBSTACLE_H    10
#define OBSTACLE_BASE_SPEED 2
#define GAME_FRAME_MS 20

// ==================== 全局对象 ====================
U8G2_SSD1306_128X64_NONAME_1_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE);
MAX30105 particleSensor;
Preferences preferences;

// ==================== 全局变量 ====================
// WiFi 配置（存储到 Preferences）
String ssid;
String password;
String weatherLocation = "ip";

// 天气数据
String weatherCity = "未知";
String weatherDesc;
String weatherTemp;
bool weatherValid = false;
unsigned long lastWeatherUpdate = 0;

// 健康数据
bool sensorReady = false;
bool dataValid = false;
unsigned long lastHealthRead = 0;
int lastHeartRate = 0;
int lastSpO2 = 0;

// 系统状态
enum AppMode { MENU_MODE, CLOCK_MODE, WEATHER_MODE, GIF_MODE, GAME_MODE, HEALTH_MODE };
AppMode currentMode = MENU_MODE;
int menuIndex = 0;           // 0:时钟,1:天气,2:动画,3:游戏,4:健康

// 菜单动画
bool menuAnimating = false;
unsigned long menuAnimStart = 0;
int menuOldIndex = 0;
int menuNewIndex = 0;

// GIF 动画
unsigned long gifStartTime = 0;

// 游戏状态
enum GameScreen { GS_DIFFICULTY, GS_READY, GS_PLAYING };
GameScreen gameState = GS_DIFFICULTY;
bool gameOverFlag = false;
float dinoY = 0;
float dinoVel = 0;
bool dinoJumping = false;
int obstacleX = 128;
int obstacleSpeed = OBSTACLE_BASE_SPEED;
int score = 0;
int lastScore = 0;
bool obstaclePassed = false;
int difficulty = 1;
unsigned long lastGameUpdate = 0;
bool gameModeJustEntered = false;

// 时钟动画
int targetDigits[6] = {0};
bool animating[6] = {false};
int oldDigits[6] = {0};
float animProgress[6] = {0.0};
unsigned long animStart[6] = {0};

// 按钮状态
bool btnLeft = false, btnRight = false, btnBack = false, btnOk = false;

// 启动日志
String logLines[4] = {"", "", "", ""};
int lineCount = 0;
bool startupDone = false;

// WiFi 重连控制
volatile bool wifiDisconnected = false;
unsigned long lastReconnectAttempt = 0;
const unsigned long RECONNECT_INTERVAL = 5000;

